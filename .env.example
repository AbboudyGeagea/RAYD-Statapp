# ── Core ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-use-a-long-random-string
TZ=Asia/Beirut

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=etl_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=etl_db

# Master admin registration key (used when creating the first admin account)
MASTER_ADMIN_KEY=change-me

# ── Feature Flags ─────────────────────────────────────────────────────────────
PATIENT_PORTAL_ENABLED=true
LIVE_FEED_ENABLED=true

# ── BitNet AI Assistant ───────────────────────────────────────────────────────
# Set to false to disable the AI assistant entirely
BITNET_ENABLED=true
# llama-server runs on the host; container reaches it via Docker bridge IP
BITNET_SERVER=http://172.17.0.1:8081
BITNET_TOKENS=200
BITNET_TIMEOUT=120
